<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Bright cyan matching the logo hex outline exactly -->
    <SolidColorBrush x:Key="PrimaryBrush"          Color="#06B6D4"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"     Color="#0891B2"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush"   Color="#0E7490"/>

    <!-- Surfaces: dark navy from logo background -->
    <SolidColorBrush x:Key="SurfaceBrush"          Color="#0F172A"/>
    <SolidColorBrush x:Key="CardBrush"             Color="#1E293B"/>
    <SolidColorBrush x:Key="RowBrush"              Color="#1E293B"/>
    <SolidColorBrush x:Key="RowHoverBrush"         Color="#293548"/>
    <SolidColorBrush x:Key="InputBgBrush"          Color="#1E293B"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextBrush"             Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextMutedBrush"        Color="#94A3B8"/>
    <SolidColorBrush x:Key="HeaderSubtextBrush"    Color="#A5F3FC"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush"           Color="#334155"/>

    <!-- Error state -->
    <SolidColorBrush x:Key="ErrorBgBrush"          Color="#450A0A"/>
    <SolidColorBrush x:Key="ErrorBorderBrush"      Color="#7F1D1D"/>
    <SolidColorBrush x:Key="ErrorTextBrush"        Color="#FCA5A5"/>

    <!-- Success state -->
    <SolidColorBrush x:Key="SuccessTextBrush"      Color="#86EFAC"/>

    <!-- Status message (settings) -->
    <SolidColorBrush x:Key="StatusOkBgBrush"       Color="#052E16"/>
    <SolidColorBrush x:Key="StatusOkBorderBrush"   Color="#166534"/>
    <SolidColorBrush x:Key="StatusOkTextBrush"     Color="#86EFAC"/>
    <SolidColorBrush x:Key="StatusErrBgBrush"      Color="#450A0A"/>
    <SolidColorBrush x:Key="StatusErrBorderBrush"  Color="#7F1D1D"/>
    <SolidColorBrush x:Key="StatusErrTextBrush"    Color="#FCA5A5"/>

</ResourceDictionary>
