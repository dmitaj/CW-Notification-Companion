<Window x:Class="CWNotificationCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CWNotificationCompanion"
        Title="CW Notification Companion"
        Icon="/Resources/CWNotify.ico"
        Width="760" MinWidth="600"
        MinHeight="150"
        SizeToContent="Height"
        Topmost="True"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
        <local:StatusBorderColorConverter x:Key="StatusBorderColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="20,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⚙ Settings" Style="{StaticResource SecondaryButton}"
                            Background="Transparent" Foreground="White"
                            BorderBrush="#FFFFFF44" Padding="10,5"
                            Click="Settings_Click" Margin="0,0,8,0"/>
                    <Button Content="↻ Refresh" Style="{StaticResource SecondaryButton}"
                            Background="Transparent" Foreground="White"
                            BorderBrush="#FFFFFF44" Padding="10,5"
                            Click="Refresh_Click" x:Name="RefreshButton"/>
                </StackPanel>
                <TextBlock x:Name="HeaderText" Foreground="White"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Error Bar -->
        <Border Grid.Row="1" x:Name="ErrorBar"
                Background="{DynamicResource ErrorBgBrush}"
                BorderBrush="{DynamicResource ErrorBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10" Visibility="Collapsed">
            <TextBlock x:Name="ErrorText"
                       Foreground="{DynamicResource ErrorTextBrush}"
                       FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2" x:Name="EmptyState" Padding="40,32" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="✓" FontSize="40"
                           Foreground="{DynamicResource SuccessTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="No pending client responses" FontSize="15"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Ticket List: MaxHeight caps growth; SizeToContent drives window height up to that point -->
        <ScrollViewer Grid.Row="2" x:Name="TicketScrollViewer"
                      MaxHeight="148"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="TicketList" Background="{DynamicResource CardBrush}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="16,12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource RowBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource RowHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Ticket # -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding IdDisplay}"
                                           FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas"/>

                                <!-- Company -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CompanyDisplay}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="8,0"/>

                                <!-- Summary -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Summary}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,12,0"/>

                                <!-- Status Badge -->
                                <Border Grid.Column="3"
                                        Background="{Binding IsSecondResponse, Converter={StaticResource StatusColorConverter}}"
                                        BorderBrush="{Binding IsSecondResponse, Converter={StaticResource StatusBorderColorConverter}}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="7,3" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding StatusDisplay}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding IsSecondResponse, Converter={StaticResource StatusColorConverter}, ConverterParameter=text}"/>
                                </Border>

                                <!-- Open in CW Button -->
                                <Button Grid.Column="4"
                                        Content="Open in CW"
                                        Style="{StaticResource OpenCWButton}"
                                        Tag="{Binding}"
                                        Click="OpenInCW_Click"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
